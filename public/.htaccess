# =====================================================================
# .htaccess para HostGator (Apache).
# Reglas: forzar HTTPS, enrutar /api/* a index.php del router, bloquear acceso
# a archivos sensibles. NO requiere mod_php especifico, solo mod_rewrite.
# =====================================================================

# Forzar HTTPS (HostGator activa HTTPS por defecto en subdominios con SSL)
# index.php es el entry point: genera el hash de app.js para cache-busting automatico.
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si HTTPS no esta activo y no es localhost, redirigir
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Enrutar todo /api/<algo> al router /api/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api/index.php [L,QSA]

    # SPA fallback: cualquier ruta que no sea archivo ni directorio -> index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>

# Bloquear acceso a archivos sensibles que pudieran subirse por error
<FilesMatch "\.(env|sql|md|sqlite|sqlite3|db|log)$">
    Require all denied
</FilesMatch>

# Bloquear directorios de configuracion
RedirectMatch 404 /\.git
RedirectMatch 404 /\.env
RedirectMatch 404 /storage
RedirectMatch 404 /api/lib/

# Bloqueo de User-Agents de scrapers y scanners a nivel Apache. Cubre tambien
# archivos estaticos (index.html, /assets/*) ademas de la API. La validacion
# fina y el log estructurado vive en api/anti_bot.php; aqui descartamos los
# casos triviales antes de llegar a PHP para no quemar CPU.
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (curl|wget|python-requests|scrapy|libwww-perl|httpclient|okhttp|go-http-client|phantomjs|headlesschrome|selenium|puppeteer|playwright|ahrefsbot|semrushbot|mj12bot|dotbot|rogerbot|blexbot|petalbot|serpstatbot|dataforseobot|screaming\ frog|sitebulb|java/|ruby|perl/|rust-reqwest|node-fetch|axios/|aiohttp|httpx|mechanize|colly|gobuster|dirbuster|wpscan|nikto|sqlmap|nmap|masscan|zgrab|censys|shodan|projectdiscovery|nuclei|feroxbuster|ffuf) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# Headers de seguridad como fallback si PHP no los emite (ej. archivos estaticos)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS activado: requiere AutoSSL activo en GoDaddy. Si HTTPS no esta
    # funcional en todos los subdominios, comentar esta linea temporalmente.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Comprimir respuestas
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# MIME types correctos para SVG inline
AddType image/svg+xml .svg
