<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         bootstrap="tests/bootstrap.php"
         colors="true"
         verbose="true"
         stopOnFailure="false"
         executionOrder="default"
         cacheResultFile=".phpunit.cache/result.cache">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="DB_DRIVER" value="sqlite"/>
        <env name="DB_SQLITE_PATH" value=":memory:"/>
        <env name="APP_KEY" value="testing_key_at_least_32_characters_long_for_csrf_and_other_signing"/>
        <env name="COOKIE_SECURE" value="false"/>
        <env name="CORS_ALLOWED_ORIGINS" value="http://localhost"/>
        <env name="SUPPORT_EMAIL" value="support@test.local"/>
    </php>
</phpunit>
