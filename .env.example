# =====================================================================
# Configuracion de entorno - Clockin/Clockout Melius Services
# =====================================================================
# Copia este archivo a .env y completa los valores reales.
# El archivo .env NUNCA se versiona (esta en .gitignore).
# En produccion (HostGator), .env debe quedar fuera de public_html si es posible,
# o protegido por .htaccess que niegue acceso HTTP.
# =====================================================================

# --- Entorno ---
# Valores: development | production
APP_ENV=development

# --- Base de datos ---
# Driver: sqlite (local) o mysql (HostGator)
DB_DRIVER=sqlite

# SQLite (solo cuando DB_DRIVER=sqlite). Ruta relativa al directorio del proyecto.
DB_SQLITE_PATH=storage/melius.db

# MySQL (solo cuando DB_DRIVER=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=melius_clock
DB_USER=usuario_db
DB_PASS=cambiar_en_produccion
DB_CHARSET=utf8mb4

# --- Sesion ---
SESSION_NAME=melius_sid
# true en produccion (HTTPS), false solo en localhost sin TLS
COOKIE_SECURE=false
# Vida de la sesion en segundos (8 horas por defecto)
SESSION_LIFETIME=28800

# --- Seguridad ---
# Token de aplicacion para firmar tokens CSRF (cualquier string aleatorio >=32 chars)
APP_KEY=cambiar_a_un_string_aleatorio_largo_de_al_menos_32_caracteres

# Maximo de intentos fallidos antes de bloqueo temporal de la cuenta
AUTH_MAX_ATTEMPTS=5
# Duracion del bloqueo en minutos
AUTH_LOCK_MINUTES=15

# CORS: dominios permitidos separados por coma. En desarrollo, http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000

# Proxies confiables (CSV de IPs o CIDRs). Solo cuando REMOTE_ADDR corresponde
# a uno de estos, se respeta el header X-Forwarded-For. Sin esta variable
# definida, XFF se ignora (defensivo contra spoofing).
# Ejemplo HostGator: TRUSTED_PROXIES=192.168.0.0/16,10.0.0.0/8
TRUSTED_PROXIES=

# --- Email de soporte (informativo, mostrado en UI) ---
SUPPORT_EMAIL=andrew.arizmendi@meliusservices.com

# --- Driver de correo ---
# resend = API HTTP via Resend (recomendado en produccion, sale por 443)
# smtp   = PHPMailer + servidor SMTP (desarrollo local o hosting que lo permita)
MAIL_DRIVER=smtp

# Dominio remitente (igual para ambos drivers).
MAIL_FROM=noreply@tudominio.com
MAIL_FROM_NAME=Melius Clockin
MAIL_REPLY_TO=soporte@tudominio.com

# --- Resend (cuando MAIL_DRIVER=resend) ---
# Genera la API key en https://resend.com/api-keys
# Verifica tu dominio en https://resend.com/domains para que SPF/DKIM queden validos.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SMTP (cuando MAIL_DRIVER=smtp) ---
# Host del servidor SMTP. Ejemplos:
#   - Titan Mail: smtp.titan.email
#   - cPanel local: localhost (requiere SMTP_INSECURE_TLS=1 por cert wildcard)
SMTP_HOST=smtp.titan.email
# Puerto: 465 (SSL implicito) o 587 (STARTTLS)
SMTP_PORT=465
# Cifrado: ssl (para 465) o tls (para 587)
SMTP_SECURE=ssl
# Cuenta autenticada (suele ser el email completo)
SMTP_USER=noreply@tudominio.com
SMTP_PASS=cambiar_en_produccion
# Desactiva verificacion de CN/CA del cert TLS (solo SMTP_HOST=localhost en hosting compartido)
SMTP_INSECURE_TLS=0
# Compat: si MAIL_FROM no esta seteado, se usa SMTP_FROM. Mismo para SMTP_FROM_NAME y SMTP_REPLY_TO.
SMTP_FROM=noreply@tudominio.com
SMTP_FROM_NAME=Melius Clockin
SMTP_REPLY_TO=soporte@tudominio.com
